{
    "code-block-style": {
        "style": "fenced"
    },
    "code-fence-style": {
        "style": "backtick"
    },
    "emphasis-style": {
        "style": "asterisk"
    },
    "fenced-code-language": {
        "allowed_languages": [
            "bash",
            "powershell",
            "html",
            "javascript",
            "json",
            "markdown",
            "mermaid",
            "text"
        ],
        "language_only": true
    },
    "heading-style": {
        "style": "atx"
    },
    "hr-style": {
        "style": "---"
    },
    "line-length": {
        "strict": true,
        "code_blocks": false,
        "tables": false
    },
    "link-image-style": {
        "inline": true,
        "full": false,
        "collapsed": false,
        "shortcut": false,
        "url_inline": true
    },
    "no-duplicate-heading": {
        "siblings_only": true
    },
    "ol-prefix": {
        "style": "ordered"
    },
    "proper-names": {
        "code_blocks": false,
        "names": [
            "Markdown",
            "SDD",
            "SFP",
            "SPEC.md",
            "Spec-First Protocol"
        ]
    },
    "reference-links-images": {
        "shortcut_syntax": true
    },
    "strong-style": {
        "style": "asterisk"
    },
    "ul-style": {
        "style": "dash"
    }
}